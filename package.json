{
  "name": "event-management-backend",
  "version": "1.0.0",
  "description": "Smart Event Management & Ticketing Backend",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:unit": "jest test/unit --runInBand",
    "test:integration": "jest test/integration --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:verbose": "jest --verbose --runInBand",
    "load:basic": "artillery run load-tests/basic-load.yml",
    "load:auth": "artillery run load-tests/auth-load.yml",
    "load:booking": "artillery run load-tests/booking-load.yml",
    "load:stress": "artillery run load-tests/stress-test.yml",
    "load:report": "artillery run --output report.json load-tests/basic-load.yml && artillery report report.json",
    "clean:db": "node scripts/cleanDatabase.js",
    "clean:db:interactive": "node scripts/cleanDatabaseInteractive.js",
    "seed": "node scripts/seedDatabase.js",
    "seed:data": "node scripts/seedData.js",
    "setup:admin": "node scripts/setupRealAdmin.js",
    "list:users": "node scripts/listAllUsers.js",
    "test:seats": "node scripts/testSeatLockSystem.js",
    "migrate": "node scripts/migrate-bookings.js",
    "create-indexes": "node scripts/create-indexes.js",
    "setup": "npm install && mkdir -p logs uploads/avatars && npm run create-indexes"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.15.4",
    "connect-timeout": "^1.9.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^166.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "recharts": "^2.10.3",
    "redis": "^4.6.10",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.18.3",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "artillery": "^2.0.27",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
